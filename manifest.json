{
    "manifest_version": 3,
    "name": "BlockTab",
    "version": "1.0",
    "description": "Stay focused. Block distractions.",
    "permissions": [
        "storage",
        "alarms",
        "tabs",
        "scripting",
        "idle"
    ],
    "host_permissions": [
        "<all_urls>"
    ],
    "background": {
        "service_worker": "background/background.js",
        "type": "module"
    },
    "content_scripts": [
        {
            "matches": [
                "*://*.youtube.com/*"
            ],
            "js": [
                "content/youtube.js"
            ]
        }
    ],
    "action": {
        "default_popup": "popup/popup.html",
        "default_icon": {
            "16": "icons/icon16.png",
            "48": "icons/icon48.png",
            "128": "icons/icon128.png"
        }
    },
    "options_ui": {
        "page": "options/options.html",
        "open_in_tab": true
    },
    "icons": {
        "16": "icons/icon16.png",
        "48": "icons/icon48.png",
        "128": "icons/icon128.png"
    },
    "web_accessible_resources": [
        {
            "resources": [
                "pages/blocked.html",
                "pages/strict.html",
                "pages/writing.html"
            ],
            "matches": [
                "<all_urls>"
            ]
        }
    ]
}